# Netlify 环境变量
# 在 Netlify Dashboard → Site settings → Environment variables 配置
# 本地开发：复制为 .env 后运行 npm run dev

COZE_TOKEN=pat_xxxxxxxx
COZE_FORTUNE_DB=your_fortune_records_database_id
COZE_USERS_DB=your_users_database_id
COZE_BASE_URL=https://api.coze.cn/v1

MINIMAX_API_KEY=sk-cp-xxxxxxxx
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=Minimax-M3

# AI 带货短剧
# Coze 工作流只负责根据商品图和介绍生成视频提示词
COZE_SHORT_DRAMA_WORKFLOW_ID=your_short_drama_prompt_workflow_id
ARK_API_KEY=ark_xxxxxxxx
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDANCE_MODEL=doubao-seedance-1-5-pro-251215

# 可选：设置后小程序请求需带 X-API-Key 头
API_SECRET=
