.welcome-page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
}

.bg-gradient {
  position: fixed;
  inset: 0;
  background: linear-gradient(160deg, #06060f 0%, #12102a 35%, #0a1a28 65%, #06060f 100%);
  z-index: 0;
}

.welcome-content {
  position: relative;
  z-index: 1;
  padding-top: 80rpx;
  text-align: center;
}

.hero-chip {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 24rpx;
  border-radius: 40rpx;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: #22D3EE;
  background: rgba(34, 211, 238, 0.08);
  border: 1rpx solid rgba(34, 211, 238, 0.2);
  margin-bottom: 20rpx;
}

.chip-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #22D3EE;
  animation: breathe 2s ease infinite;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #94A3B8;
  margin-bottom: 28rpx;
}

.hero-line {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 40rpx;
  padding: 0 40rpx;
}

.line-left, .line-right {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15));
}

.line-right {
  background: linear-gradient(90deg, rgba(255,255,255,0.15), transparent);
}

.line-glow {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #6C63FF;
  box-shadow: 0 0 20rpx #6C63FF;
}

.onboard-card {
  text-align: center;
  padding: 48rpx 40rpx;
}

.avatar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(108, 99, 255, 0.5);
  box-shadow: 0 0 40rpx rgba(108, 99, 255, 0.25);
}

.avatar-btn {
  font-size: 22rpx;
  color: #94A3B8;
  padding: 8rpx 24rpx;
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 40rpx;
  background: rgba(255,255,255,0.04);
}

.label {
  display: block;
  text-align: left;
  font-size: 24rpx;
  color: #94A3B8;
  margin-bottom: 16rpx;
}

.name-input {
  width: 100%;
  box-sizing: border-box;
  padding: 28rpx 32rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255,255,255,0.12);
  background: rgba(0,0,0,0.25);
  color: #F8FAFC;
  font-size: 30rpx;
  margin-bottom: 16rpx;
  text-align: left;
}

.hint {
  display: block;
  text-align: left;
  font-size: 22rpx;
  color: #94A3B8;
  margin-bottom: 32rpx;
  min-height: 32rpx;
}

.hint-error {
  color: #F87171;
}