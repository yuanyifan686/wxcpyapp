.home-page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 32rpx 160rpx;
}

.bg-gradient {
  position: fixed;
  inset: 0;
  background: linear-gradient(135deg, #0a0a12 0%, #1a1040 40%, #0a2030 70%, #0a0a12 100%);
  background-size: 400% 400%;
  animation: shimmer 12s ease infinite;
  z-index: 0;
}

.stars {
  position: fixed;
  inset: 0;
  z-index: 1;
  pointer-events: none;
}

.star {
  position: absolute;
  width: 4rpx;
  height: 4rpx;
  background: #fff;
  border-radius: 50%;
  opacity: 0.5;
  animation: float 4s ease-in-out infinite;
}

.header {
  position: relative;
  z-index: 2;
  text-align: center;
  margin-bottom: 60rpx;
}

.logo {
  font-size: 24rpx;
  color: #22D3EE;
  letter-spacing: 4rpx;
  display: block;
  margin-bottom: 16rpx;
}

.title {
  font-size: 52rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 16rpx;
}

.slogan {
  font-size: 26rpx;
  color: #94A3B8;
  display: block;
}

.ball-section {
  position: relative;
  z-index: 2;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.actions {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
  max-width: 400rpx;
}

.ritual-overlay {
  position: absolute;
  inset: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 32rpx 160rpx;
  background: rgba(6, 6, 15, 0.82);
  backdrop-filter: blur(12px);
}

.ritual-panel {
  width: 100%;
  max-width: 600rpx;
  padding: 48rpx 40rpx 40rpx;
  text-align: center;
  border-color: rgba(108, 99, 255, 0.25);
}

.ritual-panel.ritual-success {
  border-color: rgba(34, 211, 238, 0.45);
}

.ritual-visual {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 36rpx;
}

.ritual-orbit {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 1rpx dashed rgba(34, 211, 238, 0.35);
  animation: spin 6s linear infinite;
}

.ritual-orbit.o2 {
  inset: -20rpx;
  border-color: rgba(168, 85, 247, 0.25);
  animation-direction: reverse;
  animation-duration: 9s;
}

.ritual-core {
  position: absolute;
  inset: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  animation: breathe 2s ease-in-out infinite;
}

.ritual-stage-line {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.ritual-stage-badge {
  font-size: 18rpx;
  letter-spacing: 2rpx;
  color: #22D3EE;
  background: rgba(34, 211, 238, 0.1);
  border: 1rpx solid rgba(34, 211, 238, 0.2);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.ritual-elapsed {
  font-size: 20rpx;
  color: #64748B;
}

.ritual-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #F8FAFC;
  margin-bottom: 12rpx;
}

.ritual-msg {
  display: block;
  font-size: 24rpx;
  color: #94A3B8;
  margin-bottom: 32rpx;
  min-height: 36rpx;
}

.ritual-progress-wrap {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.ritual-progress-track {
  flex: 1;
  height: 16rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 8rpx;
  overflow: hidden;
}

.ritual-progress-fill {
  height: 100%;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #6C63FF, #A855F7, #22D3EE);
  background-size: 200% 100%;
  animation: shimmer 2s ease infinite;
  transition: width 0.15s ease-out;
}

.ritual-pct {
  font-size: 26rpx;
  font-weight: 700;
  color: #22D3EE;
  min-width: 72rpx;
}

.ritual-flavor {
  display: block;
  font-size: 22rpx;
  color: #94A3B8;
  font-style: italic;
  margin-bottom: 28rpx;
  min-height: 32rpx;
}

.ritual-steps {
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.ritual-step {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.ritual-step.active {
  background: #22D3EE;
  box-shadow: 0 0 16rpx rgba(34, 211, 238, 0.5);
  transform: scale(1.2);
}

.ritual-step.done {
  background: #6C63FF;
  opacity: 0.7;
}