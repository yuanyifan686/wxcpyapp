<view class="home-page">
  <view class="bg-gradient"></view>
  <view class="stars">
    <view wx:for="{{stars}}" wx:key="id" class="star" style="left:{{item.x}}%;top:{{item.y}}%;animation-delay:{{item.delay}}s;"></view>
  </view>

  <view class="header fade-in">
    <text class="logo">⚡ CYBER FORTUNE</text>
    <text class="title gradient-text">今日赛博运势</text>
    <text class="slogan">宇宙服务器今日已同步你的幸运值</text>
  </view>

  <view class="ball-section">
    <loading-ball
      hint="{{hasOfficialToday ? '✨ 点击查看今日运势' : '✨ 点击获取今日运势'}}"
      animating="{{animating}}"
      exploding="{{exploding}}"
      level="{{todayLevel}}"
      bind:tap="onBallTap"
    />
  </view>

  <view class="actions fade-in">
    <glass-button wx:if="{{hasOfficialToday}}" text="查看今日结果" bind:tap="goResult" />
    <glass-button wx:if="{{hasOfficialToday}}" text="娱乐重抽" type="ghost" bind:tap="onRegenerate" />
  </view>

  <view wx:if="{{ritualVisible}}" class="ritual-overlay">
    <view class="ritual-panel glass-card {{ritualSuccess ? 'ritual-success' : ''}}">
      <view class="ritual-visual">
        <view class="ritual-orbit o1"></view>
        <view class="ritual-orbit o2"></view>
        <text class="ritual-core">🔮</text>
      </view>
      <view class="ritual-stage-line">
        <text class="ritual-stage-badge">{{ritualStage}}</text>
        <text class="ritual-elapsed">{{ritualElapsed}}</text>
      </view>
      <text class="ritual-title">{{ritualTitle}}</text>
      <text class="ritual-msg">{{ritualMsg}}</text>
      <view class="ritual-progress-wrap">
        <view class="ritual-progress-track">
          <view class="ritual-progress-fill" style="width:{{ritualProgress}}%"></view>
        </view>
        <text class="ritual-pct">{{ritualPct}}%</text>
      </view>
      <text class="ritual-flavor">💬 {{ritualFlavor}}</text>
      <view class="ritual-steps">
        <view
          wx:for="{{ritualStepList}}"
          wx:key="*this"
          class="ritual-step {{ritualStep > item ? 'done' : ''}} {{ritualStep === item ? 'active' : ''}}"
        ></view>
      </view>
    </view>
  </view>
</view>