.ball-wrap {
  position: relative;
  width: 480rpx;
  height: 480rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ball-aura {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}

.ball-aura-gold {
  width: 460rpx;
  height: 460rpx;
  background: radial-gradient(circle, rgba(255, 215, 0, 0.28) 0%, rgba(255, 180, 0, 0.08) 45%, transparent 72%);
  animation: auraBreatheGold 3.2s ease-in-out infinite;
}

.ball-aura-silver {
  width: 510rpx;
  height: 510rpx;
  background: radial-gradient(circle, rgba(220, 225, 255, 0.22) 0%, rgba(192, 192, 192, 0.08) 50%, transparent 75%);
  animation: auraBreatheSilver 2.6s ease-in-out infinite 0.6s;
}

@keyframes auraBreatheGold {
  0%, 100% { opacity: 0.35; transform: translate(-50%, -50%) scale(0.96); }
  50% { opacity: 0.95; transform: translate(-50%, -50%) scale(1.08); }
}

@keyframes auraBreatheSilver {
  0%, 100% { opacity: 0.25; transform: translate(-50%, -50%) scale(1); }
  50% { opacity: 0.9; transform: translate(-50%, -50%) scale(1.1); }
}

.ball-wrap.aura-ssr .ball {
  border-color: rgba(255, 215, 0, 0.5);
  box-shadow: 0 0 72rpx rgba(255, 215, 0, 0.4), inset 0 0 48rpx rgba(255, 215, 0, 0.08);
}

.ball-wrap.aura-ssr .ball-aura-gold { animation-duration: 2.4s; }

.ball-wrap.aura-sr .ball {
  border-color: rgba(210, 215, 230, 0.55);
  animation: breathe 3s ease-in-out infinite, silverBallPulse 2.2s ease-in-out infinite;
}

.ball-wrap.aura-sr .ball-aura-silver { animation-duration: 1.8s; }

@keyframes silverBallPulse {
  0%, 100% { box-shadow: 0 0 48rpx rgba(192, 192, 210, 0.35); }
  50% { box-shadow: 0 0 88rpx rgba(230, 235, 255, 0.55); }
}

.particles {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.particle {
  position: absolute;
  width: 6rpx;
  height: 6rpx;
  background: #22D3EE;
  border-radius: 50%;
  opacity: 0.6;
  animation: float 3s ease-in-out infinite;
}

.ball {
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(20px);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: breathe 3s ease-in-out infinite, pulse-glow 3s ease-in-out infinite;
  transition: transform 0.3s ease;
}

.ball.animating {
  animation: spin 2s linear, pulse-glow 0.5s ease-in-out infinite;
}

.ball.exploding {
  animation: explode 0.6s ease forwards;
}

.ball-inner {
  text-align: center;
  padding: 40rpx;
}

.ball-glow {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(108, 99, 255, 0.4), transparent);
  filter: blur(20px);
}

.ball-text {
  font-size: 30rpx;
  color: #F8FAFC;
  line-height: 1.6;
  position: relative;
  z-index: 1;
}

.explosion-ring {
  position: absolute;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(34, 211, 238, 0.6);
  animation: ringExpand 0.8s ease forwards;
}

@keyframes explode {
  0% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.2); opacity: 0.8; }
  100% { transform: scale(0.8); opacity: 0.3; }
}

@keyframes ringExpand {
  from { transform: scale(1); opacity: 1; }
  to { transform: scale(2); opacity: 0; }
}