.buff-grid {
  padding: 28rpx;
}

.grid-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.grid-item {
  background: rgba(255, 255, 255, 0.04);
  border-radius: 16rpx;
  padding: 20rpx 12rpx;
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.item-emoji {
  display: block;
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.item-label {
  display: block;
  font-size: 20rpx;
  color: #94A3B8;
  margin-bottom: 4rpx;
}

.item-value {
  display: block;
  font-size: 24rpx;
  color: #F8FAFC;
  font-weight: 500;
}