.energy-bar {
  padding: 28rpx;
}

.energy-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.energy-label {
  font-size: 26rpx;
  color: #94A3B8;
}

.energy-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #22D3EE;
}

.energy-track {
  height: 16rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 8rpx;
  overflow: hidden;
}

.energy-fill {
  height: 100%;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #6C63FF, #A855F7, #22D3EE);
  background-size: 200% 100%;
  animation: shimmer 2s ease infinite;
  transition: width 1s ease;
}